# ---------------------------------------------------------------------
# Glivt backend environment template. Copy to .env and fill in real values.
# NEVER commit .env. No production secret is baked into the source.
# ---------------------------------------------------------------------

# --- Database (MySQL) ---
DB_URL=jdbc:mysql://localhost:3306/glivt?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=glivt
DB_PASSWORD=change-me

# --- JWT ---
# Must be at least 32 characters. Generate a strong random value in production.
APP_JWT_SECRET=change-me-to-a-long-random-secret-value-min-32-chars
APP_JWT_ACCESS_TTL_MINUTES=15
APP_JWT_REFRESH_TTL_DAYS=30

# --- Auth policy ---
APP_AUTH_SINGLE_SESSION=false
APP_AUTH_LOGIN_MAX_ATTEMPTS=5
APP_AUTH_LOGIN_WINDOW_MINUTES=15

# --- CORS (comma-separated origins; use explicit origins in production) ---
APP_CORS_ALLOWED_ORIGINS=*

# --- Demo data seeding (keep false in production) ---
APP_SEED_DEMO=false

# --- Reserved for later slices (not used yet) ---
# GEOAPIFY_API_KEY=
# FIREBASE_CREDENTIALS_PATH=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
