DB_URL=jdbc:mysql://localhost:3306/glivt?useSSL=true&serverTimezone=UTC
DB_USERNAME=glivt
DB_PASSWORD=change-me

APP_JWT_SECRET=replace-with-at-least-32-random-bytes
APP_JWT_ACCESS_TTL_MINUTES=15
APP_JWT_REFRESH_TTL_DAYS=30
APP_AUTH_SINGLE_SESSION=false
APP_AUTH_LOGIN_MAX_ATTEMPTS=5
APP_AUTH_LOGIN_WINDOW_MINUTES=15
APP_CORS_ALLOWED_ORIGINS=https://app.example.com
APP_SEED_DEMO=false

# --- AI Fleet Intelligence ---
# Shared secret between Spring Boot and the Python AI service. MUST be identical
# to the Python service's AI_INTERNAL_TOKEN. If unset, AI calls are rejected and
# the platform transparently falls back to deterministic rule-based results.
AI_INTERNAL_TOKEN=
AI_PYTHON_SERVICE_URL=http://127.0.0.1:8001
AI_PYTHON_SERVICE_TIMEOUT=5000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3.5:2b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

GEOAPIFY_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
